# .env.example
# Copy this file to .env and fill in your values
# DO NOT commit .env, .env.local, or deploy/railway.env.generated to git!
# For local tests: copy .env.test.example → .env.test (also gitignored)
# 
# 🔐 IMPORTANT: Generate strong secrets using:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    Or online: https://generate-secret.vercel.app/32

# ============ FRONTEND CONFIG ============
# Development:
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
# Production (same Docker/Railway host — leave SOCKET empty for auto origin):
# VITE_API_URL=/api
# VITE_SOCKET_URL=
# VITE_ENVIRONMENT=production
VITE_APP_NAME=Tra Da Mentor
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug
VITE_SENTRY_DSN=

# ============ BACKEND CONFIG ============
NODE_ENV=development
PORT=5000
HOST=localhost

# ============ DATABASE ============
DATABASE_URL=mongodb://localhost:27017/tra-da-mentor
MONGO_USER=
MONGO_PASSWORD=

# ============ AUTHENTICATION ============
# 🔐 REQUIRED: Generate secure random strings (min 64 characters)
# Use: openssl rand -hex 64
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_64_CHARS_LONG_USE_OPENSSL_RAND_HEX_64
JWT_EXPIRE=7d

# Google SSO (optional – redirect URI: {BASE_URL}/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_SECURE_RANDOM_STRING_AT_LEAST_64_CHARS_LONG_USE_OPENSSL_RAND_HEX_64
JWT_REFRESH_EXPIRE=30d

# ============ SECURITY ============
# Production CORS should be your frontend domain only
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Rate limiting (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ============ MONITORING (Optional) ============
# Backend: SENTRY_DSN — Frontend: VITE_SENTRY_DSN (same Sentry project DSN is fine)
SENTRY_DSN=
MONITORING_ENABLED=false

# ============ PRODUCTION ADMIN (first deploy) ============
# node scripts/create-admin.mjs admin@your.org "Admin Name" 'YourSecurePass!'
# Or: npm run create:admin -- admin@your.org "Admin Name" 'YourSecurePass!'

# ============ DEMO AUTH (dev only) ============
# Set false in production. In production, set true only if you need admin@example.com demo login.
ENABLE_DEMO_AUTH=true
# Never enable demo admin in production (server will refuse to start)

# ============ PRODUCTION SINGLE-HOST (Railway / Render / Docker) ============
# NODE_ENV=production
# HOST=0.0.0.0
# PORT=5000
# BASE_URL=https://your-app.up.railway.app
# FRONTEND_URL=https://your-app.up.railway.app
# CORS_ORIGIN=https://your-app.up.railway.app
# ENABLE_DEMO_AUTH=false
# VITE_API_URL=/api
# VITE_SOCKET_URL=
# VITE_ENVIRONMENT=production

# ============ SENDGRID EMAIL ============
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@tradamentor.com
SENDGRID_FROM_NAME=Trà Đá Mentor

# ============ ZALO OA (optional broadcast) ============
ZALO_OA_ACCESS_TOKEN=
ZALO_BROADCAST_USER_IDS=

# ============ STRIPE ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# ============ EMAIL (SMTP fallback) ============
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
