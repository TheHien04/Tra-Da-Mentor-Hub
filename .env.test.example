# Template for local E2E/tests only — copy to .env.test (gitignored)
# CI uses workflow env vars; do not put real secrets here.

NODE_ENV=test
PORT=5001
HOST=localhost
DATABASE_URL=mongodb://127.0.0.1:27017/tra-da-mentor-test
JWT_SECRET=test-jwt-secret-key-for-testing-only-not-for-production
JWT_REFRESH_SECRET=test-jwt-refresh-secret-key-for-testing-only-not-for-production
CORS_ORIGIN=http://localhost:5173
ENABLE_DEMO_AUTH=true
LOG_LEVEL=error
