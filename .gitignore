# =============================================================================
# Trà Đá Mentor — .gitignore (security-first)
# Only commit: source code, .env.example, deploy/*.template, public assets.
# NEVER commit: secrets, .env, build output, test artifacts, local deploy files.
# =============================================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build & bundler output ---
dist/
dist-ssr/
build/
out/
.cache/
.vite/
*.tsbuildinfo

# --- Environment & secrets (CRITICAL) ---
.env
.env.*
!.env.example
!.env.test.example
backend/.env
backend/.env.*

# Generated deploy env (contains real JWT from npm run setup:deploy)
deploy/*.generated
deploy/*.local
deploy/railway.env
deploy/*.env
!deploy/.gitkeep
!deploy/*.template

# Keys, certs, cloud credentials
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
credentials.json
**/credentials.json
**/*-credentials.json
**/service-account*.json
**/secrets.json
**/*.secret
.gcloud/
.terraform/
*.tfvars
*.tfstate
*.tfstate.*

# --- Logs & runtime data ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend/logs/
pids/
*.pid

# --- Databases & dumps ---
*.sqlite
*.sqlite3
*.db
dump.rdb
*.sql.gz

# --- Test & coverage (never commit CI/local artifacts) ---
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
playwright/.cache/
.jest/

# --- Large / local-only assets ---
src/assets/logo-source.png
docs/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Editors & IDE ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-workspace
*.sublime-project
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# --- Temp & backups ---
*.tmp
*.temp
*.bak
*.orig
package-lock.json.bak
*~

# --- Hosting / PaaS local config ---
.vercel
.netlify
.railway/
.render/

# --- Misc local ---
*.local
Tra-Da-Mentor-Hub/
